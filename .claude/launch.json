{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "elections",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('.',req.url==='/'?'/index.html':req.url);try{res.writeHead(200,{'Content-Type':f.endsWith('.html')?'text/html':'application/octet-stream'});res.end(fs.readFileSync(f))}catch(e){res.writeHead(404);res.end()}}).listen(4200)"],
      "port": 4200
    },
    {
      "name": "israelis-nl",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "4201"],
      "port": 4201
    }
  ]
}
